# Neon Postgres connection string (use the pooled connection for serverless)
# Get this from https://console.neon.tech (Connection Details → Pooled connection)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Direct (non-pooled) URL — used by Prisma migrations
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Required in development; Vercel sets this automatically in prod
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional — create at https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
