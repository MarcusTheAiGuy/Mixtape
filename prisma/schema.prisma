// Mixtape — Prisma schema
// Datasource: Neon Postgres

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ────────────────────────────────────────────────────────────
// NextAuth (Auth.js v5) — Prisma adapter models
// ────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  bio           String?
  location      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  taste     TasteEntry[]
  moods     MoodEntry[]
  wishlist  WishlistShow[]
  hosted    Meetup[]   @relation("MeetupHost")
  attending Attendee[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ────────────────────────────────────────────────────────────
// Taste profile — identity ("all-time") + monthly mood
// ────────────────────────────────────────────────────────────

enum TasteCategory {
  ALBUM
  ARTIST
  GENRE
  SONG
  LIVE_SHOW
}

// Identity-layer top 5s — one per (user, category, position 1..5).
// Position is 1..5. Fewer than 5 entries is allowed.
model TasteEntry {
  id         String        @id @default(cuid())
  userId     String
  category   TasteCategory
  position   Int
  name       String
  subtitle   String?
  imageUrl   String?
  externalId String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, position])
  @@index([userId])
  @@index([category, name])
}

// Monthly mood — same shape as TasteEntry, scoped to a YYYY-MM key.
model MoodEntry {
  id         String        @id @default(cuid())
  userId     String
  monthKey   String
  category   TasteCategory
  position   Int
  name       String
  subtitle   String?
  imageUrl   String?
  externalId String?
  createdAt  DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, monthKey, category, position])
  @@index([userId, monthKey])
}

// Future shows the user wants to go to. Public so others can request to tag along.
model WishlistShow {
  id        String    @id @default(cuid())
  userId    String
  artist    String
  artistMbid String?
  tourName  String?
  venue     String?
  city      String?
  date      DateTime?
  url       String?
  notes     String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

// ────────────────────────────────────────────────────────────
// Meetups
// ────────────────────────────────────────────────────────────

model Meetup {
  id           String     @id @default(cuid())
  title        String
  description  String?
  venue        String
  city         String
  startsAt     DateTime
  endsAt       DateTime?
  hostId       String
  // Free-form taste filters (e.g. "shoegaze", "Big Thief").
  // Used to surface this meetup to people whose taste matches.
  tasteFilters String[]   @default([])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  host      User       @relation("MeetupHost", fields: [hostId], references: [id], onDelete: Cascade)
  attendees Attendee[]

  @@index([hostId])
  @@index([startsAt])
}

model Attendee {
  meetupId String
  userId   String
  joinedAt DateTime @default(now())

  meetup Meetup @relation(fields: [meetupId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([meetupId, userId])
}
